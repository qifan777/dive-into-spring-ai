# Export these variables in your shell or IDE run configuration before starting the backend.

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/knowledge_base
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=123456

# Redis Stack
SPRING_DATA_REDIS_PASSWORD=123456

# Neo4j
SPRING_NEO4J_URI=bolt://localhost:7687
SPRING_NEO4J_AUTHENTICATION_USERNAME=neo4j
SPRING_NEO4J_AUTHENTICATION_PASSWORD=12345678

# First-run AI provider
SPRING_AI_DASH_SCOPE_API_KEY=REPLACE_ME
SPRING_AI_DASH_SCOPE_CHAT_OPTIONS_MODEL=qwen-max
SPRING_AI_DASH_SCOPE_EMBEDDING_OPTIONS_MODEL=text-embedding-v2

# Optional local runtime helpers
SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434
CODE_ASSISTANT_PROJECT_PROJECT_PATH=/absolute/path/to/your/project
